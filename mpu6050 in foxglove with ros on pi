cd ~/ros2_ws/src
# Wipe out any previous failed folders first
rm -rf ros2_mpu6050 ros2_mpu6050_driver

# Download via the flat zip archive stream to bypass port blocks
wget https://github.com/hiwad-aziz/ros2_mpu6050_driver/archive/refs/heads/main.zip

# Extract it cleanly
sudo apt update && sudo apt install -y unzip
unzip main.zip

# Rename the folder to match what the ROS 2 package expects
mv ros2_mpu6050_driver-main ros2_mpu6050_driver
rm main.zip
cd ~/ros2_ws
colcon build --packages-select mpu6050driver
source /opt/ros/humble/setup.bash
source ~/ros2_ws/install/setup.bash
ros2 launch mpu6050driver mpu6050driver_launch.py
