  #!/usr/bin/env python3
# ~/esp32_bridge.py

import rclpy
from rclpy.node import Node
from std_msgs.msg import Float32, Int32
import serial, json, threading

class ESP32Bridge(Node):
    def __init__(self):
        super().__init__('esp32_bridge')

        # Check port: ls /dev/ttyUSB* or /dev/ttyACM*
        self.ser = serial.Serial('/dev/ttyUSB0', 115200, timeout=1)

        self.tds_pub = self.create_publisher(Float32, '/water/tds', 10)
        self.pwm_pub = self.create_publisher(Int32, '/esp32/pwm_echo', 10)
        self.create_subscription(Int32, '/cmd/pwm', self.on_pwm_cmd, 10)

        threading.Thread(target=self.read_loop, daemon=True).start()
        self.get_logger().info('ESP32 bridge running')

    def read_loop(self):
        while rclpy.ok():
            try:
                line = self.ser.readline().decode('utf-8').strip()
                if not line: continue
                d = json.loads(line)
                if 'tds' in d:
                    self.tds_pub.publish(Float32(data=float(d['tds'])))
                if 'pwm' in d:
                    self.pwm_pub.publish(Int32(data=int(d['pwm'])))
            except: pass

    def on_pwm_cmd(self, msg):
        pwm = max(1000, min(2000, msg.data))
        self.ser.write((json.dumps({'pwm': pwm}) + '\n').encode())
        self.get_logger().info(f'→ ESP32 PWM: {pwm}')

def main():
    rclpy.init()
    rclpy.spin(ESP32Bridge())

if __name__ == '__main__':
    main()


