   // esp32_bridge.ino
#include <ESP32Servo.h>

#define TDS_PIN 34
#define ESC_PIN 25

Servo esc;
int currentPWM = 1000;

void setup() {
  Serial.begin(115200);
  esc.attach(ESC_PIN, 1000, 2000);
  esc.writeMicroseconds(1000);  // arm signal
  delay(3000);                  // wait for ESC to arm
  Serial.println("{\"status\":\"armed\"}");
}

float readTDS() {
  int raw = analogRead(TDS_PIN);
  float v = raw * 3.3f / 4095.0f;
  return (133.42f*v*v*v - 255.86f*v*v + 857.39f*v) * 0.5f;
}

void loop() {
  // Non-blocking serial read for PWM command
  while (Serial.available()) {
    String line = Serial.readStringUntil('\n');
    line.trim();
    int idx = line.indexOf("\"pwm\":");
    if (idx != -1) {
      int val = line.substring(idx + 6).toInt();
      currentPWM = constrain(val, 1000, 2000);
      esc.writeMicroseconds(currentPWM);
    }
  }

  // Publish sensor + feedback JSON
  Serial.print("{\"tds\":");
  Serial.print(readTDS(), 1);
  Serial.print(",\"pwm\":");
  Serial.print(currentPWM);
  Serial.println("}");

  delay(500);
}

